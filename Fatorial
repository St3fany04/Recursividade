/**
 * Classe que implementa o cálculo de fatorial de um número
 * em modo iterativo e modo recursivo.
 */
public class Fatorial {
    private int numero;

    /**
     * Construtor da classe Fatorial
     * @param numero o número para o qual deseja calcular o fatorial
     */
    public Fatorial(int numero) {
        this.numero = numero;
    }

    /**
     * Calcula o fatorial de um número de forma iterativa.
     * Utiliza um loop para multiplicar todos os números de 1 até n.
     * 
     * Caso base: fatorial(0) = 1
     * Caso iterativo: n! = 1 * 2 * 3 * ... * n
     * 
     * @return o fatorial do número
     */
    public long fatorialIterativo() {
        return fatorialIterativo(this.numero);
    }

    /**
     * Calcula o fatorial de um número de forma iterativa.
     * 
     * @param numero o número para o qual deseja calcular o fatorial
     * @return o fatorial do número
     */
    public long fatorialIterativo(int numero) {
        if (numero < 0) {
            throw new IllegalArgumentException("Fatorial não é definido para números negativos!");
        }
        
        if (numero == 0 || numero == 1) {
            return 1;
        }

        long resultado = 1;
        for (int i = 2; i <= numero; i++) {
            resultado *= i;
        }
        return resultado;
    }

    /**
     * Calcula o fatorial de um número de forma recursiva.
     * A função chama a si mesma até atingir o caso base.
     * 
     * Caso base: fatorial(0) = 1, fatorial(1) = 1
     * Caso recursivo: fatorial(n) = n * fatorial(n-1)
     * 
     * @return o fatorial do número
     */
    public long fatorialRecursivo() {
        return fatorialRecursivo(this.numero);
    }

    /**
     * Calcula o fatorial de um número de forma recursiva.
     * A função chama a si mesma, reduzindo o problema a cada chamada.
     * 
     * @param numero o número para o qual deseja calcular o fatorial
     * @return o fatorial do número
     */
    public long fatorialRecursivo(int numero) {
        // Validação: números negativos não têm fatorial definido
        if (numero < 0) {
            throw new IllegalArgumentException("Fatorial não é definido para números negativos!");
        }
        
        // CASO BASE: garantia de saída da recursão
        if (numero == 0 || numero == 1) {
            return 1;
        }
        
        // CASO RECURSIVO: chamada da função a si mesma com um problema menor
        return numero * fatorialRecursivo(numero - 1);
    }

    /**
     * Getter para o número armazenado
     * @return o número
     */
    public int getNumero() {
        return numero;
    }

    /**
     * Setter para o número
     * @param numero o novo número
     */
    public void setNumero(int numero) {
        this.numero = numero;
    }
}
